{
  "name": "ast-outline-mcp",
  "version": "1.4.9",
  "type": "module",
  "description": "MCP server for ast-outline - a tree-sitter-based CLI that provides structural code outlines, digests, symbol extraction, and AST-aware grep",
  "main": "dist/index.js",
  "bin": {
    "ast-outline-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "start:http": "node dist/server/http-server.js",
    "dev": "tsc --watch",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "lint": "eslint src tests --max-warnings 0",
    "lint:fix": "eslint src tests --fix",
    "prepare": "husky",
    "release": "./scripts/release.sh"
  },
  "keywords": [
    "mcp",
    "ast-outline",
    "code-analysis",
    "tree-sitter",
    "model-context-protocol"
  ],
  "author": "Xayan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xayan/ast-outline-mcp.git"
  },
  "dependencies": {
    "fastmcp": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.ts": "eslint --fix --max-warnings 0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "tldjs@2.3.2": true,
    "unrs-resolver@1.12.2": true
  }
}
